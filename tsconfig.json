{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./TypeScript",
    "strict": true,
    "lib": ["esnext", "dom"],
    "skipLibCheck": true
  },
  "include": ["TypeScript/**/*"],
  "exclude": ["node_modules", "dist"]
}
